# Leapmotor Webapp — Environment Configuration
# Copy this file to .env and fill in your certificate paths.

# Path to the app certificate PEM file (required)
APP_CERT_PATH=/path/to/app-cert.pem

# Path to the app key PEM file (required)
APP_KEY_PATH=/path/to/app-key.pem

# Account P12 password (optional — usually auto-derived)
ACCOUNT_P12_PASSWORD=

# Path to the SQLite database for vehicle history (optional, defaults to ./history.db)
# HISTORY_DB_PATH=/path/to/history.db
# ACCOUNT_P12_PASSWORD=
